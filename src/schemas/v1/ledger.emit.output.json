{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "chittycanon://core/services/chittyconnect/schemas/v1/ledger.emit.output",
  "type": "object",
  "required": ["ledger_event_id", "entry_hash", "domain"],
  "additionalProperties": false,
  "properties": {
    "ledger_event_id": { "type": "string" },
    "entry_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "domain": { "type": "string", "const": "git" }
  }
}
