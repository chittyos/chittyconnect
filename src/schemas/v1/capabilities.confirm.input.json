{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "chittycanon://core/services/chittyconnect/schemas/v1/capabilities.confirm.input",
  "type": "object",
  "required": ["caller_chittyid", "tenant_id", "repo_path", "remote", "ref", "force_class"],
  "additionalProperties": false,
  "properties": {
    "caller_chittyid": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2}-[A-Z0-9]-[A-Z0-9]{3}-[A-Z0-9]{4}-[PLTEA]-[0-9]{4}-[0-5]-[0-9]{2}$"
    },
    "tenant_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "repo_path": { "type": "string", "minLength": 1 },
    "remote": { "type": "string", "minLength": 1 },
    "ref": { "type": "string", "minLength": 1 },
    "force_class": { "type": "string", "enum": ["force", "force_with_lease"] }
  }
}
