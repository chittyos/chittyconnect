{
  // ChittyConnect - itsChitty™
  // The AI-intelligent spine with ContextConsciousness & MemoryCloude
  //
  // Routes:
  // - /api/* - REST API for custom GPT Actions
  // - /mcp/* - MCP protocol for Claude integration
  // - /integrations/github/webhook - GitHub App integration
  //
  // Environment model (canonical):
  //   dev       → wrangler dev (local)
  //   staging   → wrangler deploy --env staging
  //   production → wrangler deploy --env production

  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "chittyconnect",
  "main": "src/index.js",
  "compatibility_date": "2026-03-02",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "0bc21e3a5a9de1a4cc843be9c3e98121",

  // ──────────────────────────────────────────────────────────────────
  // SHARED BINDINGS (inherited by all environments)
  // ──────────────────────────────────────────────────────────────────

  // R2 bucket for shared files
  "r2_buckets": [
    { "binding": "FILES", "bucket_name": "chittyos-files" }
  ],

  // KV Namespaces — production IDs at top level, preview_id auto-created by wrangler dev
  "kv_namespaces": [
    { "binding": "IDEMP_KV", "id": "9ad1ec9795d243ca94f7502e6efb6a62" },
    { "binding": "TOKEN_KV", "id": "788d2fce231d4819a11b46d5f4678b04" },
    { "binding": "API_KEYS", "id": "cf6da7757caf4da5a8a365be2174f391" },
    // OAuth 2.1 token storage (required by @cloudflare/workers-oauth-provider)
    // OAUTH_PROVIDER binding is auto-injected by @cloudflare/workers-oauth-provider at runtime.
    { "binding": "OAUTH_KV", "id": "054ff38c93854e7c87b3aa307a7759cc" },
    { "binding": "CREDENTIAL_CACHE", "id": "aa18a59a2eb24fb29cfe08ef62519f4d" },
    { "binding": "RATE_LIMIT", "id": "1ab2c1114f5c4e248b8eba157615a125" },
    { "binding": "TENANT_CONNECTIONS", "id": "a1a42192fca34c7cbec8dd3df3d53d54" }
  ],

  // Vectorize for MemoryCloude and ContextConsciousness
  "vectorize": [
    { "binding": "MEMORY_VECTORIZE", "index_name": "memory-cloude" },
    { "binding": "CONTEXT_VECTORIZE", "index_name": "context-embeddings" }
  ],

  // Durable Objects — McpAgent-backed MCP sessions
  "durable_objects": {
    "bindings": [
      { "name": "MCP_AGENT", "class_name": "McpConnectAgent", "script_name": "chittyconnect" }
    ]
  },

  // DO Migrations
  // Production is at tag "v3" with MCPSessionDurableObject (legacy stub).
  // v4 deletes the old stub and creates McpConnectAgent with SQLite for Agents SDK.
  "migrations": [
    { "tag": "v3", "new_classes": ["MCPSessionDurableObject"] },
    { "tag": "v4", "deleted_classes": ["MCPSessionDurableObject"], "new_sqlite_classes": ["McpConnectAgent"] }
  ],

  // D1 Database for installation mapping
  "d1_databases": [
    { "binding": "DB", "database_name": "chittyconnect", "database_id": "29473911-4c5b-47d8-a3e7-d1be2370edf6" }
  ],

  // Queues for async event processing
  "queues": {
    "producers": [
      { "binding": "EVENT_Q", "queue": "github-events" },
      { "binding": "PROOF_Q", "queue": "documint-proofs" }
    ],
    "consumers": [
      { "queue": "documint-proofs", "max_batch_size": 10, "max_retries": 5, "dead_letter_queue": "documint-proofs-dlq" }
    ]
  },

  // Cloudflare Workers AI binding
  "ai": { "binding": "AI" },

  // Build configuration
  "build": { "command": "", "cwd": "." },

  // Analytics and logging
  "observability": { "enabled": true },

  // ChittyTrack observability
  "tail_consumers": [{ "service": "chittytrack" }],

  // ──────────────────────────────────────────────────────────────────
  // ENVIRONMENTS
  // ──────────────────────────────────────────────────────────────────

  "env": {

    // ════════════════════════════════════════════════════════════════
    // DEV — local development via `wrangler dev`
    // ════════════════════════════════════════════════════════════════
    "dev": {
      "vars": {
        "ENVIRONMENT": "development",
        // ChittyOS service URLs (local or dev instances)
        "CHITTYID_SERVICE_URL": "https://id.chitty.cc",
        "CHITTYAUTH_SERVICE_URL": "https://auth.chitty.cc",
        "REGISTRY_SERVICE_URL": "https://registry.chitty.cc",
        "CHITTYCHRONICLE_SERVICE_URL": "https://chronicle.chitty.cc",
        "CHITTYMINT_URL": "https://mint.chitty.cc",
        "CHITTYCONNECT_URL": "http://localhost:8787",
        "CHITTYROUTER_URL": "https://router.chitty.cc",
        "CHITTY_FALLBACK_URL": "https://fallback.id.chitty.cc",
        "CHITTYSERV_URL": "http://chittyserv-dev:8080",
        // Ollama / AI model routing
        "OLLAMA_URL": "https://ollama.chitty.cc/v1/chat/completions",
        "AI_MODEL_PRIMARY": "@cf/meta/llama-4-scout-17b-16e-instruct",
        // Cloudflare & Neon identifiers
        "CHITTYOS_ACCOUNT_ID": "0bc21e3a5a9de1a4cc843be9c3e98121",
        "CHITTYOS_DOMAIN": "chitty.cc",
        "NEON_ORG_ID": "org-old-mountain-22774840",
        // 1Password Connect
        "ONEPASSWORD_CONNECT_URL": "https://1password-connect.chitty.cc",
        "ONEPASSWORD_VAULT_INFRASTRUCTURE": "oxwo63jlcbo66c7kwx67lquw4i",
        "ONEPASSWORD_VAULT_SERVICES": "xgevq7nkt6t4bfokjaczht5gdy",
        "ONEPASSWORD_VAULT_INTEGRATIONS": "3ngilqu4qsp4mlr53xhvyi4sry",
        "ONEPASSWORD_VAULT_EMERGENCY": "shl646vf4snnrkx6linyk3yis4",
        // Credential broker config
        "CREDENTIAL_FAILOVER_ENABLED": "true",
        "CREDENTIAL_BROKER_TYPE": "auto",
        // Feature flags
        "EVIDENCE_LEGACY_MODE": "false",
        // Neon secret rotation defaults
        "NEON_ROLE_NAME": "chittyos_app",
        "NEON_DATABASE": "neondb"
      }
    },

    // ════════════════════════════════════════════════════════════════
    // STAGING — `wrangler deploy --env staging`
    // ════════════════════════════════════════════════════════════════
    "staging": {
      "name": "chittyconnect-staging",
      "vars": {
        "ENVIRONMENT": "staging",
        // ChittyOS service URLs (production services, staging worker)
        "CHITTYID_SERVICE_URL": "https://id.chitty.cc",
        "CHITTYAUTH_SERVICE_URL": "https://auth.chitty.cc",
        "REGISTRY_SERVICE_URL": "https://registry.chitty.cc",
        "CHITTYCHRONICLE_SERVICE_URL": "https://chronicle.chitty.cc",
        "CHITTYMINT_URL": "https://mint.chitty.cc",
        "CHITTYCONNECT_URL": "https://connect-staging.chitty.cc",
        "CHITTYROUTER_URL": "https://router.chitty.cc",
        "CHITTY_FALLBACK_URL": "https://fallback.id.chitty.cc",
        // Ollama / AI model routing
        "OLLAMA_URL": "https://ollama.chitty.cc/v1/chat/completions",
        "AI_MODEL_PRIMARY": "@cf/meta/llama-4-scout-17b-16e-instruct",
        // Cloudflare & Neon identifiers
        "CHITTYOS_ACCOUNT_ID": "0bc21e3a5a9de1a4cc843be9c3e98121",
        "CHITTYOS_DOMAIN": "chitty.cc",
        "NEON_ORG_ID": "org-old-mountain-22774840",
        // 1Password Connect
        "ONEPASSWORD_CONNECT_URL": "https://1password-connect.chitty.cc",
        "ONEPASSWORD_VAULT_INFRASTRUCTURE": "oxwo63jlcbo66c7kwx67lquw4i",
        "ONEPASSWORD_VAULT_SERVICES": "xgevq7nkt6t4bfokjaczht5gdy",
        "ONEPASSWORD_VAULT_INTEGRATIONS": "3ngilqu4qsp4mlr53xhvyi4sry",
        "ONEPASSWORD_VAULT_EMERGENCY": "shl646vf4snnrkx6linyk3yis4",
        // Credential broker config
        "CREDENTIAL_FAILOVER_ENABLED": "true",
        "CREDENTIAL_BROKER_TYPE": "auto",
        // Feature flags
        "EVIDENCE_LEGACY_MODE": "false",
        // Neon secret rotation defaults
        "NEON_ROLE_NAME": "chittyos_app",
        "NEON_DATABASE": "neondb"
      }
    },

    // ════════════════════════════════════════════════════════════════
    // PRODUCTION — `wrangler deploy --env production`
    // ════════════════════════════════════════════════════════════════
    "production": {
      "name": "chittyconnect",
      "routes": [
        { "pattern": "connect.chitty.cc/*", "zone_name": "chitty.cc" },
        { "pattern": "mcp.chitty.cc/*", "zone_name": "chitty.cc" }
        // Note: api.chitty.cc/* still assigned to chittyapi-production worker.
        // To consolidate, delete that worker first, then add:
        // { "pattern": "api.chitty.cc/*", "zone_name": "chitty.cc" }
      ],
      "vars": {
        "ENVIRONMENT": "production",
        // ChittyOS service URLs
        "CHITTYID_SERVICE_URL": "https://id.chitty.cc",
        "CHITTYAUTH_SERVICE_URL": "https://auth.chitty.cc",
        "REGISTRY_SERVICE_URL": "https://registry.chitty.cc",
        "CHITTYCHRONICLE_SERVICE_URL": "https://chronicle.chitty.cc",
        "CHITTYMINT_URL": "https://mint.chitty.cc",
        "CHITTYCONNECT_URL": "https://connect.chitty.cc",
        "CHITTYROUTER_URL": "https://router.chitty.cc",
        "CHITTY_FALLBACK_URL": "https://fallback.id.chitty.cc",
        // Ollama / AI model routing
        "OLLAMA_URL": "https://ollama.chitty.cc/v1/chat/completions",
        "AI_MODEL_PRIMARY": "@cf/meta/llama-4-scout-17b-16e-instruct",
        // Cloudflare & Neon identifiers
        "CHITTYOS_ACCOUNT_ID": "0bc21e3a5a9de1a4cc843be9c3e98121",
        "CHITTYOS_DOMAIN": "chitty.cc",
        "NEON_ORG_ID": "org-old-mountain-22774840",
        // 1Password Connect
        "ONEPASSWORD_CONNECT_URL": "https://1password-connect.chitty.cc",
        "ONEPASSWORD_VAULT_INFRASTRUCTURE": "oxwo63jlcbo66c7kwx67lquw4i",
        "ONEPASSWORD_VAULT_SERVICES": "xgevq7nkt6t4bfokjaczht5gdy",
        "ONEPASSWORD_VAULT_INTEGRATIONS": "3ngilqu4qsp4mlr53xhvyi4sry",
        "ONEPASSWORD_VAULT_EMERGENCY": "shl646vf4snnrkx6linyk3yis4",
        // Credential broker config
        "CREDENTIAL_FAILOVER_ENABLED": "true",
        "CREDENTIAL_BROKER_TYPE": "auto",
        // Feature flags
        "EVIDENCE_LEGACY_MODE": "false",
        // Neon secret rotation defaults
        "NEON_ROLE_NAME": "chittyos_app",
        "NEON_DATABASE": "neondb"
      },

      // Scheduled triggers — production only
      "triggers": {
        "crons": [
          "0 * * * *",     // Hourly: 1Password event sync + secret rotation check
          "*/5 * * * *",   // Every 5 min: Connection health checks
          "*/50 * * * *"   // Every 50 min: OAuth token rotation (GDrive access tokens)
        ]
      }
    }
  }

  // ──────────────────────────────────────────────────────────────────
  // SECRETS MANIFEST
  // ──────────────────────────────────────────────────────────────────
  // All secrets are set via: wrangler secret put <NAME> --env <ENV>
  // Source of truth: 1Password → Cloudflare Secrets (hot runtime delivery)
  // KV is ONLY for short-lived rotated values (sessions, API keys, rate limits).
  //
  // ┌─────────────────────────────────────────────────────────────────┐
  // │ GITHUB INTEGRATION                                             │
  // ├─────────────────────────────────────────────────────────────────┤
  // │ GITHUB_APP_ID              GitHub App numeric ID               │
  // │ GITHUB_APP_PK              GitHub App private key (PEM)        │
  // │ GITHUB_WEBHOOK_SECRET      Webhook signature verification      │
  // └─────────────────────────────────────────────────────────────────┘
  //
  // ┌─────────────────────────────────────────────────────────────────┐
  // │ CHITTYOS SERVICE TOKENS (pattern: CHITTY_${SERVICE}_TOKEN)     │
  // ├─────────────────────────────────────────────────────────────────┤
  // │ CHITTY_ID_TOKEN            ChittyID service auth               │
  // │ CHITTY_AUTH_TOKEN          ChittyAuth service auth             │
  // │ CHITTY_REGISTRY_TOKEN      ChittyRegistry service auth         │
  // │ CHITTY_CHRONICLE_TOKEN     ChittyChronicle service auth        │
  // │ CHITTY_DNA_TOKEN           ChittyDNA service auth              │
  // │ CHITTY_VERIFY_TOKEN        ChittyVerify service auth           │
  // │ CHITTY_CERTIFY_TOKEN       ChittyCertify service auth          │
  // │ CHITTY_CASES_TOKEN         ChittyCases service auth            │
  // │ CHITTY_FINANCE_TOKEN       ChittyFinance service auth          │
  // │ CHITTY_EVIDENCE_TOKEN      ChittyEvidence service auth         │
  // │ CHITTY_SYNC_TOKEN          ChittySync service auth             │
  // │ CHITTY_PROOF_TOKEN         ChittyProof service auth            │
  // │ CHITTY_TRUST_TOKEN         ChittyTrust service auth            │
  // │ CHITTY_CONTEXTUAL_TOKEN    ChittyContextual service auth       │
  // │ CHITTY_TASK_TOKEN          ChittyTask service auth             │
  // │ CHITTY_SERV_TOKEN          ChittyServ homelab auth             │
  // │ CHITTY_ID_SERVICE_TOKEN    ChittyID generic service token      │
  // │ CHITTYCONNECT_SERVICE_TOKEN ChittyConnect self-service token   │
  // │ CHITTYMINT_SECRET          ChittyMint webhook secret           │
  // │ CHITTY_TRACK_TOKEN         ChittyTrack observability token     │
  // └─────────────────────────────────────────────────────────────────┘
  //
  // ┌─────────────────────────────────────────────────────────────────┐
  // │ THIRD-PARTY INTEGRATIONS                                       │
  // ├─────────────────────────────────────────────────────────────────┤
  // │ NOTION_TOKEN               Notion API integration              │
  // │ OPENAI_API_KEY             OpenAI API key                      │
  // │ GOOGLE_ACCESS_TOKEN        Google OAuth access token            │
  // │ GDRIVE_CLIENT_ID           Google Drive OAuth client ID        │
  // │ GDRIVE_CLIENT_SECRET       Google Drive OAuth client secret    │
  // │ OLLAMA_CF_CLIENT_ID        Cloudflare Access client ID (Ollama)│
  // │ OLLAMA_CF_CLIENT_SECRET    Cloudflare Access client secret     │
  // │ TWILIO_ACCOUNT_SID         Twilio account SID                  │
  // │ TWILIO_AUTH_TOKEN          Twilio auth token                   │
  // │ AI_SEARCH_TOKEN            AI search integration token         │
  // └─────────────────────────────────────────────────────────────────┘
  //
  // ┌─────────────────────────────────────────────────────────────────┐
  // │ NEON DATABASE                                                  │
  // ├─────────────────────────────────────────────────────────────────┤
  // │ NEON_DATABASE_URL          Neon connection string (verify)     │
  // │ NEON_API_KEY               Neon API key (secret rotation)     │
  // │ NEON_PROJECT_ID            Neon project ID                     │
  // │ NEON_BRANCH_ID             Neon branch ID                      │
  // │ NEON_HOST                  Neon host                           │
  // └─────────────────────────────────────────────────────────────────┘
  //
  // ┌─────────────────────────────────────────────────────────────────┐
  // │ CREDENTIAL PROVISIONING & 1PASSWORD                            │
  // ├─────────────────────────────────────────────────────────────────┤
  // │ ONEPASSWORD_CONNECT_TOKEN  1Password Connect JWT               │
  // │ OP_EVENTS_API_TOKEN        1Password Events API token          │
  // │ CLOUDFLARE_MAKE_API_KEY    CF API fallback (if 1Pass down)     │
  // │ CLOUDFLARE_ACCOUNT_ID      CF account fallback                 │
  // │ EMERGENCY_REVOKE_TOKEN     Emergency credential revocation     │
  // │ ENCRYPTION_KEY             32-byte key for KV cache encryption │
  // │ INTERNAL_WEBHOOK_SECRET    Internal webhook verification       │
  // └─────────────────────────────────────────────────────────────────┘
  //
  // ┌─────────────────────────────────────────────────────────────────┐
  // │ NON-SECRET VARS (in [vars], not secrets)                       │
  // ├─────────────────────────────────────────────────────────────────┤
  // │ TWILIO_PHONE_NUMBER        Twilio sender phone number          │
  // │ (Move to vars when Twilio integration is promoted)             │
  // └─────────────────────────────────────────────────────────────────┘
  //
  // ┌─────────────────────────────────────────────────────────────────┐
  // │ CODE ALIASES (not separate secrets — resolve to above)         │
  // ├─────────────────────────────────────────────────────────────────┤
  // │ CF_ACCOUNT_ID              → CHITTYOS_ACCOUNT_ID (var)         │
  // │ CHITTY_SERVICE_TOKEN       → CHITTY_ID_SERVICE_TOKEN (secret)  │
  // │ CHITTY_API_KEY             → API_KEYS KV lookup (binding)      │
  // └─────────────────────────────────────────────────────────────────┘
  //
  // ┌─────────────────────────────────────────────────────────────────┐
  // │ PHANTOM BINDINGS (referenced, not yet provisioned)             │
  // ├─────────────────────────────────────────────────────────────────┤
  // │ COMMAND_KV, CONVERSATIONS, CONTEXT_CONSCIOUSNESS,              │
  // │ MEMORY_KV (falls back to TOKEN_KV), PREDICTION_CACHE,         │
  // │ SESSION_STATE, DOCUMENT_STORAGE, CHRONICLE_KV                  │
  // │ Guarded with optional chaining. Provision as KV namespaces     │
  // │ when features are promoted to production.                      │
  // └─────────────────────────────────────────────────────────────────┘
  //
  // 1Password vault items required for credential provisioning:
  //   Vault: ChittyOS-Core (oxwo63jlcbo66c7kwx67lquw4i)
  //   Item title: "cloudflare"  fields: make_api_key, account_id
}
